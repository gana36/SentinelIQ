# App
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
MOCK_MODE=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentineliq

# Redis
REDIS_URL=redis://localhost:6379/0

# AWS Bedrock
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
BEDROCK_NOVA_LITE_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_NOVA_SONIC_MODEL_ID=amazon.nova-sonic-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.nova-multimodal-embedding-v1

# Data Sources (only needed when MOCK_MODE=false)
NEWSAPI_KEY=your-newsapi-key
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=SentinelIQ/1.0 by YourUsername
POLYGON_API_KEY=your-polygon-api-key

# LangSmith observability (get key at smith.langchain.com)
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=sentineliq
